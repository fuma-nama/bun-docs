{
  "name": "fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun pull-docs && next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "types:check": "tsc --noEmit",
    "pull-docs": "bun scripts/pull-docs.ts --download-only",
    "sync-docs": "bun scripts/pull-docs.ts && bun migrate-docs.ts && git apply manual-fixes.patch --reject",
    "sync-docs:save": "bun scripts/pull-docs.ts && bun migrate-docs.ts && git diff -R content/ > manual-fixes.patch && git restore content/",
    "check-links": "bun scripts/check-links.ts",
    "build:static": "bun scripts/cf-pages-build.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.170",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@types/bun": "^1.3.13",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.8.2",
    "fumadocs-mdx": "14.3.1",
    "fumadocs-ui": "16.8.2",
    "gatsby-remark-find-replace": "^0.3.0",
    "geist": "^1.7.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "next-validate-link": "^1.6.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-tweet": "^3.3.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "@types/mdx": "^2.0.13",
    "@tailwindcss/postcss": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "postcss": "^8.5.10"
  }
}
